{
    "name": "Dream vortex",
    "description": "Pulls in nearby entities while channelling, blinding and slowing them. After the channel ends, bring yourself and all affected entities to the dream realm. When used in the dream realm, can still affect entities in the overworld.",
    "type": "origins:multiple",
    "badges": [{
        "type": "origins:tooltip",
        "sprite": "origins:textures/gui/badge/active.png",
        "text": {
            "text": "Primary key while looking straight up"
        }
    }],
    "active": {
        "type": "origins:active_self",
        "key": {
            "key": "key.origins.primary_active",
            "continuous": true
        },
        "entity_action": {
            "type": "origins:if_else_list",
            "actions": [{
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:nevariin/rotation_rotation",
                        "compare_to": 2,
                        "comparison": "!="
                    },
                    "action": {
                        "type": "origins:nothing"
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 0,
                        "comparison": ">",
                        "resource": "*:*_cooldown"
                    },
                    "action": {
                        "type": "origins:nothing"
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 0,
                        "comparison": "==",
                        "resource": "*:nevariin/channel_primary"
                    },
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary",
                                "change": 1,
                                "operation": "set"
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/function foxpaw:nevariin/dream_vortex/place"
                            }
                        ]
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:and",
                        "conditions": [{
                                "type": "origins:resource",
                                "compare_to": 20,
                                "comparison": ">=",
                                "resource": "*:nevariin/channel_primary"
                            },
                            {
                                "type": "origins:sneaking"
                            }
                        ]
                    },
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:execute_command",
                                "command": "function foxpaw:nevariin/dream_sickle/slash"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary",
                                "change": 0,
                                "operation": "set"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:*_cooldown",
                                "change": 1000000000,
                                "operation": "set"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary_channeling",
                                "operation": "set",
                                "change": 0
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/execute if dimension minecraft:overworld in foxpaw:dream_world run tp @s ~ ~ ~ "
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/function foxpaw:nevariin/dream_vortex/warp"
                            },
                            {
                                "type": "origins:area_of_effect",
                                "radius": 5,
                                "shape": "sphere",
                                "bientity_action": {
                                    "type": "origins:target_action",
                                    "action": {
                                        "type": "origins:apply_effect",
                                        "effects": [{
                                                "id": "minecraft:slowness",
                                                "amplifier": 5,
                                                "duration": 60
                                            },
                                            {
                                                "id": "minecraft:weakness",
                                                "amplifier": 5,
                                                "duration": 60
                                            },
                                            {
                                                "id": "minecraft:blindness",
                                                "amplifier": 5,
                                                "duration": 60
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    }
                },
                {
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary",
                                "change": 1,
                                "operation": "add"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary_channeling",
                                "change": 5,
                                "operation": "set"
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/particle cloud ~ ~ ~ 0 0 0 0.3 5"
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "function foxpaw:nevariin/dream_vortex/tick"
                            }
                        ]
                    },
                    "condition": {
                        "type": "origins:constant",
                        "value": true
                    }
                }
            ]
        },
        "cooldown": 1
    },
    "cooldown": {
        "type": "origins:resource",
        "min": 0,
        "max": 150,
        "start_value": 0,
        "hud_render": {
            "sprite_location": "origins:textures/gui/resource_bar.png",
            "bar_index": 3,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_cooldown",
                "compare_to": 0,
                "comparison": ">"
            }
        }
    },
    "release": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:and",
            "actions": [{
                    "type": "origins:change_resource",
                    "resource": "*:*_cooldown",
                    "change": -1,
                    "operation": "add"
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:and",
                        "conditions": [{
                                "type": "origins:resource",
                                "compare_to": 0,
                                "comparison": "==",
                                "resource": "*:nevariin/channel_primary"
                            },
                            {
                                "type": "origins:resource",
                                "compare_to": 0,
                                "comparison": "==",
                                "resource": "*:nevariin/channel_primary_channeling"
                            }
                        ]
                    },
                    "if_action": {
                        "type": "origins:execute_command",
                        "command": "execute as @e[type=armor_stand,tag=nevariin_dream_vortex] at @s run function foxpaw:nevariin/dream_vortex/clear"
                    }
                }
            ]
        }
    }
}