{
    "name": "Seal of binding",
    "description": "After a brief channel, hover off the ground and gain true vision of nearby entities. Holding recast will send you flying towards the target, capturing the nearest entity in a radius and trapping both of you inside an unbreakable seal that lasts until either dies or 30 seconds has passed.",
    "type": "origins:multiple",
    "badges": [{
        "type": "origins:tooltip",
        "sprite": "origins:textures/gui/badge/active.png",
        "text": {
            "text": "Primary key while looking straight down"
        }
    }],
    "active": {
        "type": "origins:active_self",
        "key": {
            "key": "key.origins.primary_active",
            "continuous": true
        },
        "entity_action": {
            "type": "origins:if_else_list",
            "actions": [{
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 0,
                        "comparison": ">",
                        "resource": "*:*_cooldown"
                    },
                    "action": {
                        "type": "origins:nothing"
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 1,
                        "comparison": "==",
                        "resource": "*:*_charging"
                    },
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary_channeling",
                                "change": 10000000,
                                "operation": "set"
                            },
                            {
                                "type": "origins:selector_action",
                                "selector": "@e[type=minecraft:armor_stand,tag=nevariin_charge_target]",
                                "bientity_action": {
                                    "type": "origins:and",
                                    "actions": [{
                                            "type": "origins:invert",
                                            "action": {
                                                "type": "origins:add_velocity",
                                                "z": -0.5,
                                                "reference": "position"
                                            }
                                        },
                                        {
                                            "type": "origins:if_else",
                                            "condition": {
                                                "type": "origins:distance",
                                                "compare_to": 5,
                                                "comparison": "<"
                                            },
                                            "if_action": {
                                                "type": "origins:and",
                                                "actions": [{
                                                        "type": "origins:target_action",
                                                        "action": {
                                                            "type": "origins:execute_command",
                                                            "command": "/kill @s"
                                                        }
                                                    },
                                                    {
                                                        "type": "origins:actor_action",
                                                        "action": {
                                                            "type": "origins:and",
                                                            "actions": [{
                                                                    "type": "origins:change_resource",
                                                                    "resource": "*:*_charging",
                                                                    "operation": "set",
                                                                    "change": 0
                                                                },
                                                                {
                                                                    "type": "origins:change_resource",
                                                                    "resource": "*:*_channel_done",
                                                                    "operation": "set",
                                                                    "change": 0
                                                                },
                                                                {
                                                                    "type": "origins:change_resource",
                                                                    "resource": "*:nevariin/channel_primary",
                                                                    "change": 0,
                                                                    "operation": "set"
                                                                },
                                                                {
                                                                    "type": "origins:execute_command",
                                                                    "command": "/attribute @s minecraft:generic.gravity modifier remove nevariin_gravity"
                                                                },
                                                                {
                                                                    "type": "origins:add_velocity",
                                                                    "set": true
                                                                },
                                                                {
                                                                    "type": "origins:area_of_effect",
                                                                    "radius": 5,
                                                                    "shape": "sphere",
                                                                    "bientity_condition": {
                                                                        "type": "origins:and",
                                                                        "conditions": [{
                                                                                "type": "origins:target_condition",
                                                                                "condition": {
                                                                                    "type": "origins:living"
                                                                                }
                                                                            },
                                                                            {
                                                                                "type": "origins:target_condition",
                                                                                "condition": {
                                                                                    "type": "origins:entity_type",
                                                                                    "entity_type": "minecraft:armor_stand",
                                                                                    "inverted": true
                                                                                }
                                                                            }
                                                                        ]
                                                                    },
                                                                    "bientity_action": {
                                                                        "type": "origins:and",
                                                                        "actions": [{
                                                                            "type": "origins:actor_action",
                                                                            "action": {
                                                                                "type": "origins:execute_command",
                                                                                "command": "tag @s add nevariin_bound"
                                                                            }
                                                                        }, {
                                                                            "type": "origins:target_action",
                                                                            "action": {
                                                                                "type": "origins:and",
                                                                                "actions": [{
                                                                                        "type": "origins:execute_command",
                                                                                        "command": "/execute in foxpaw:dream_world run tp @s ~ ~ ~"
                                                                                    },
                                                                                    {
                                                                                        "type": "origins:execute_command",
                                                                                        "command": "tag @s add nevariin_bound"
                                                                                    },
                                                                                    {
                                                                                        "type": "origins:execute_command",
                                                                                        "command": "/function foxpaw:nevariin/seal_of_binding/summon_seal"
                                                                                    }
                                                                                ]
                                                                            }
                                                                        }]
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    }
                                                ]
                                            }
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 1,
                        "comparison": "==",
                        "resource": "*:*_aiming"
                    },
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:*_aiming",
                                "operation": "set",
                                "change": 0
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:*_charging",
                                "operation": "set",
                                "change": 1
                            },
                            {
                                "type": "origins:raycast",
                                "block": false,
                                "entity": true,
                                "entity_distance": 200,
                                "bientity_condition": {
                                    "type": "origins:and",
                                    "conditions": [{
                                        "type": "origins:target_condition",
                                        "condition": {
                                            "type": "origins:living"
                                        }
                                    }]
                                },
                                "bientity_action": {
                                    "type": "origins:and",
                                    "actions": [{
                                        "type": "origins:target_action",
                                        "action": {
                                            "type": "origins:execute_command",
                                            "command": "/function foxpaw:nevariin/seal_of_binding/summon_charge_dummy"
                                        }
                                    }]
                                }
                            },
                            {
                                "type": "origins:raycast",
                                "block": true,
                                "entity": false,
                                "block_distance": 200,
                                "command_at_hit": "/function foxpaw:nevariin/seal_of_binding/summon_charge_dummy"
                            },
                            {
                                "type": "origins:selector_action",
                                "selector": "@e",
                                "bientity_action": {
                                    "type": "origins:target_action",
                                    "action": {
                                        "type": "origins:remove_power",
                                        "power": "*:nevariin/subobject/seal_target_highlight"
                                    }
                                }
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary_channeling",
                                "operation": "set",
                                "change": 1000000
                            },
                            {
                                "type": "origins:if_else",
                                "condition": {
                                    "type": "origins:command",
                                    "command": "execute unless entity @e[tag=nevariin_charge_target] run return 1",
                                    "compare_to": 1,
                                    "comparison": "=="
                                },
                                "if_action": {
                                    "type": "origins:and",
                                    "actions": [{
                                            "type": "origins:change_resource",
                                            "resource": "*:*_charging",
                                            "operation": "set",
                                            "change": 0
                                        },
                                        {
                                            "type": "origins:change_resource",
                                            "resource": "*:*_channel_done",
                                            "operation": "set",
                                            "change": 0
                                        },
                                        {
                                            "type": "origins:change_resource",
                                            "resource": "*:nevariin/channel_primary",
                                            "change": 0,
                                            "operation": "set"
                                        },
                                        {
                                            "type": "origins:execute_command",
                                            "command": "/attribute @s minecraft:generic.gravity modifier remove nevariin_gravity"
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "compare_to": 1,
                        "comparison": "==",
                        "resource": "*:*_channel_done"
                    },
                    "action": {
                        "type": "origins:nothing"
                    }
                },
                {
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:nevariin/rotation_rotation",
                        "compare_to": 0,
                        "comparison": "!="
                    },
                    "action": {
                        "type": "origins:nothing"
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:and",
                        "conditions": [{
                            "type": "origins:resource",
                            "compare_to": 20,
                            "comparison": ">=",
                            "resource": "*:nevariin/channel_primary"
                        }]
                    },
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:execute_command",
                                "command": "/function foxpaw:nevariin/seal_of_binding/reset"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:*_channel_done",
                                "operation": "set",
                                "change": 1
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/attribute @s minecraft:generic.gravity modifier add nevariin_gravity -0.09 add_value"
                            },
                            {
                                "type": "origins:delay",
                                "ticks": 10,
                                "action": {
                                    "type": "origins:and",
                                    "actions": [{
                                            "type": "origins:execute_command",
                                            "command": "/attribute @s minecraft:generic.gravity modifier remove nevariin_gravity"
                                        },
                                        {
                                            "type": "origins:execute_command",
                                            "command": "/attribute @s minecraft:generic.gravity modifier add nevariin_gravity -0.07 add_value"
                                        },
                                        {
                                            "type": "origins:delay",
                                            "ticks": 30,
                                            "action": {
                                                "type": "origins:and",
                                                "actions": [{
                                                        "type": "origins:change_resource",
                                                        "resource": "*:*_aiming",
                                                        "operation": "set",
                                                        "change": 1
                                                    },
                                                    {
                                                        "type": "origins:area_of_effect",
                                                        "radius": 200,
                                                        "shape": "sphere",
                                                        "bientity_action": {
                                                            "type": "origins:target_action",
                                                            "action": {
                                                                "type": "origins:grant_power",
                                                                "power": "*:nevariin/subobject/seal_target_highlight",
                                                                "source": "binding"
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary",
                                "change": 1,
                                "operation": "add"
                            },
                            {
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary_channeling",
                                "change": 10000000,
                                "operation": "set"
                            },
                            {
                                "type": "origins:execute_command",
                                "command": "/particle cloud ~ ~ ~ 0 0 0 0.3 5"
                            }
                        ]
                    },
                    "condition": {
                        "type": "origins:constant",
                        "value": true
                    }
                }
            ]
        },
        "cooldown": 1
    },
    "cooldown": {
        "type": "origins:resource",
        "min": 0,
        "max": 500,
        "start_value": 0,
        "hud_render": {
            "sprite_location": "origins:textures/gui/resource_bar.png",
            "bar_index": 3,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_cooldown",
                "compare_to": 0,
                "comparison": ">"
            }
        }
    },
    "channel_done": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0
    },
    "aiming": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0
    },
    "charging": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0
    },
    "crawl": {
        "type": "origins:pose",
        "condition": {
            "type": "origins:resource",
            "compare_to": 1,
            "comparison": "==",
            "resource": "*:*_charging"
        },
        "entity_pose": "swimming"
    },
    "phase": {
        "type": "origins:phasing",
        "condition": {
            "type": "origins:resource",
            "compare_to": 1,
            "comparison": "==",
            "resource": "*:*_charging"
        },
        "render_type": "remove_blocks"
    },
    "release": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:and",
            "actions": [{
                    "type": "origins:change_resource",
                    "resource": "*:*_cooldown",
                    "change": -1,
                    "operation": "add"
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:and",
                        "conditions": [{
                            "type": "origins:resource",
                            "compare_to": 1,
                            "comparison": "==",
                            "resource": "*:*_channel_done"
                        }]
                    },
                    "if_action": {
                        "type": "origins:and",
                        "actions": [{
                                "type": "origins:change_resource",
                                "resource": "*:nevariin/channel_primary",
                                "change": 1000000000,
                                "operation": "set"
                            },
                            {
                                "type": "origins:if_else",
                                "if_action": {
                                    "type": "origins:change_resource",
                                    "change": 1,
                                    "operation": "set",
                                    "resource": "*:*_channel_done"
                                },
                                "condition": {
                                    "type": "origins:sneaking"
                                }
                            },
                            {
                                "type": "origins:if_else",
                                "condition": {
                                    "type": "origins:and",
                                    "conditions": [{
                                            "type": "origins:resource",
                                            "compare_to": 1,
                                            "comparison": "==",
                                            "resource": "*:*_charging"
                                        },
                                        {
                                            "type": "origins:resource",
                                            "compare_to": 0,
                                            "comparison": "==",
                                            "resource": "*:nevariin/channel_primary_channeling"
                                        }
                                    ]
                                },
                                "if_action": {
                                    "type": "origins:and",
                                    "actions": [{
                                            "type": "origins:change_resource",
                                            "resource": "*:*_charging",
                                            "operation": "set",
                                            "change": 0
                                        },
                                        {
                                            "type": "origins:change_resource",
                                            "resource": "*:*_channel_done",
                                            "operation": "set",
                                            "change": 0
                                        },
                                        {
                                            "type": "origins:execute_command",
                                            "command": "/kill @e[type=minecraft:armor_stand,tag=nevariin_charge_target]"
                                        },
                                        {
                                            "type": "origins:change_resource",
                                            "resource": "*:nevariin/channel_primary",
                                            "change": 0,
                                            "operation": "set"
                                        },
                                        {
                                            "type": "origins:execute_command",
                                            "command": "/attribute @s minecraft:generic.gravity modifier remove nevariin_gravity"
                                        },
                                        {
                                            "type": "origins:add_velocity",
                                            "set": true
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                }
            ]
        }
    },
    "callback": {
        "type": "origins:action_on_callback",
        "entity_action_added": {
            "type": "origins:execute_command",
            "command": "/function foxpaw:nevariin/seal_of_binding/reset"
        },
        "entity_action_respawned": {
            "type": "origins:execute_command",
            "command": "/function foxpaw:nevariin/seal_of_binding/reset"
        }
    }
}