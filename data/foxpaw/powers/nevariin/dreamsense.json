{
    "name": "Dreamsense",
    "description": "Shows you the location of nearby entities, even in different dimensions. Much weaker in the overworld.",
    "type": "origins:active_self",
    "cooldown": 20,
    "entity_action": {
        "type": "origins:and",
        "actions": [{
            "type": "origins:if_else",
            "condition": {
                "type": "origins:dimension",
                "dimension": "foxpaw:dream_world"
            },
            "if_action": {
                "type": "origins:and",
                "actions": [{
                        "type": "origins:execute_command",
                        "command": "function foxpaw:nevariin/dreamsense/dream_world"
                    },
                    {
                        "type": "origins:area_of_effect",
                        "shape": "sphere",
                        "radius": "300",
                        "bientity_action": {
                            "type": "origins:target_action",
                            "action": {
                                "type": "origins:grant_power",
                                "power": "*:nevariin/subobject/dreamsense_highlight"
                            }
                        }
                    }
                ]
            },
            "else_action": {
                "type": "origins:and",
                "actions": [{
                        "type": "origins:execute_command",
                        "command": "function foxpaw:nevariin/dreamsense/overworld"
                    },
                    {
                        "type": "origins:area_of_effect",
                        "shape": "sphere",
                        "radius": "100",
                        "bientity_action": {
                            "type": "origins:target_action",
                            "action": {
                                "type": "origins:grant_power",
                                "power": "*:nevariin/subobject/dreamsense_highlight"
                            }
                        }
                    }
                ]
            }
        }]
    },
    "key": {
        "key": "key.origins.secondary_active",
        "continuous": false
    },
    "hud_render": {
        "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
        "bar_index": 7
    }
}